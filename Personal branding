<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Gazul Gafoor — F&B Operations & Franchise Systems</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Syne:wght@400;600;700;800&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#040407;
  --card:#0A0A10;
  --card2:#0F0F16;
  --border:rgba(255,255,255,0.055);
  --border-gold:rgba(201,168,76,0.22);
  --gold:#C9A84C;
  --gold2:#E4C86E;
  --gold3:#F6E4A8;
  --glow:rgba(201,168,76,0.08);
  --glow2:rgba(201,168,76,0.14);
  --text:#EDE9DF;
  --text2:rgba(237,233,223,0.6);
  --text3:rgba(237,233,223,0.32);
  --muted:#484860;
  --dim:#1A1A26;
  --green:#1DB954;
  --blue:#4C9EFF;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Manrope',sans-serif;min-height:100svh;display:flex;align-items:flex-start;justify-content:center;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");opacity:.022}
.bg{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.orb{position:absolute;border-radius:50%;filter:blur(140px);animation:drift 26s ease-in-out infinite alternate}
.o1{width:700px;height:700px;background:#B8922C;opacity:.075;top:-280px;left:-260px}
.o2{width:550px;height:550px;background:#0E2878;opacity:.09;bottom:-150px;right:-200px;animation-delay:-11s}
.o3{width:320px;height:320px;background:#6B2FAF;opacity:.045;top:45%;left:55%;animation-delay:-18s}
.o4{width:200px;height:200px;background:#C9A84C;opacity:.04;top:30%;right:5%;animation-delay:-7s}
@keyframes drift{from{transform:translate(0,0)}to{transform:translate(45px,55px)}}
.wrap{position:relative;z-index:1;width:100%;max-width:500px;padding:60px 20px 88px;display:flex;flex-direction:column;align-items:center}

/* HERO */
.av-wrap{position:relative;margin-bottom:24px;animation:up .8s .05s ease both}
.av-ring{width:96px;height:96px;border-radius:50%;padding:2.5px;background:conic-gradient(from 0deg,var(--gold3) 0%,var(--gold) 20%,rgba(255,255,255,.04) 38%,var(--gold2) 52%,var(--gold3) 60%,rgba(255,255,255,.04) 78%,var(--gold) 88%,var(--gold3) 100%);animation:spin 9s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.av-inner{width:100%;height:100%;border-radius:50%;background:radial-gradient(circle at 35% 35%,#18181F,#0A0A10);border:1px solid var(--dim);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--gold);letter-spacing:-1px}
.live-dot{position:absolute;bottom:5px;right:3px;width:14px;height:14px;border-radius:50%;background:var(--green);border:3px solid var(--bg);animation:blink 2.4s ease infinite}
@keyframes blink{0%,100%{box-shadow:0 0 0 0 rgba(29,185,84,.55)}55%{box-shadow:0 0 0 9px rgba(29,185,84,0)}}
.name{font-family:'Syne',sans-serif;font-size:clamp(30px,8.5vw,38px);font-weight:800;letter-spacing:-1.5px;text-align:center;background:linear-gradient(140deg,var(--gold3) 0%,var(--gold2) 30%,var(--gold) 60%,#fff4c2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:up .8s .12s ease both}
.serif-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(16px,4.5vw,21px);font-weight:500;color:var(--text3);text-align:center;margin-top:8px;margin-bottom:6px;line-height:1.4;animation:up .8s .18s ease both}
.tagline-sub{font-size:11.5px;color:var(--text3);text-align:center;margin-bottom:22px;line-height:1.7;max-width:320px;animation:up .8s .22s ease both}
.tagline-sub strong{color:var(--text2);font-weight:600}
.role-strip{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:28px;animation:up .8s .27s ease both}
.rtag{font-size:9px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;padding:5px 13px;border-radius:100px}
.rg{color:var(--gold2);background:var(--glow);border:1px solid var(--border-gold)}
.rb{color:#9BC8FF;background:rgba(76,158,255,.08);border:1px solid rgba(76,158,255,.16)}
.rp{color:#C4A0FF;background:rgba(159,111,232,.08);border:1px solid rgba(159,111,232,.16)}
.rd{color:var(--muted);background:transparent;border:1px solid var(--dim)}
.grule{width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:4px 0 28px;animation:up .8s .3s ease both}

/* SECTION LABEL */
.sec{width:100%;font-size:8.5px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:10px;margin-bottom:12px;margin-top:26px}
.sec::before{content:'';width:16px;height:1px;background:linear-gradient(90deg,transparent,var(--gold));flex-shrink:0}
.sec::after{content:'';flex:1;height:1px;background:var(--border)}

/* STORY */
.story{width:100%;background:linear-gradient(145deg,var(--card2),var(--card));border:1px solid var(--border);border-left:2px solid var(--gold);border-radius:18px;padding:24px 22px;margin-bottom:12px;box-shadow:0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.04);animation:up .8s .32s ease both}
.story-lbl{font-size:8.5px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:14px}
.story p{font-size:12.5px;line-height:1.9;color:var(--text3)}
.story p strong{color:var(--text2);font-weight:600}
.story p+p{margin-top:11px}

/* STATS */
.stats{display:flex;width:100%;background:linear-gradient(135deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-bottom:12px;box-shadow:0 8px 32px rgba(0,0,0,.35);animation:up .8s .36s ease both}
.stat{flex:1;padding:18px 6px;text-align:center;position:relative}
.stat:not(:last-child)::after{content:'';position:absolute;right:0;top:20%;height:60%;width:1px;background:linear-gradient(180deg,transparent,var(--border),transparent)}
.sn{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;background:linear-gradient(135deg,var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.sl{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:5px;line-height:1.4}

/* CREDENTIALS */
.cred-wrap{width:100%;display:flex;flex-direction:column;gap:10px;margin-bottom:4px}
.cred{width:100%;border-radius:18px;border:1px solid var(--border-gold);background:linear-gradient(145deg,rgba(201,168,76,.07),rgba(201,168,76,.02),var(--card));box-shadow:0 4px 30px rgba(201,168,76,.06),0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(201,168,76,.12);animation:up .8s ease both;position:relative;overflow:hidden}
.cred::before{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(201,168,76,.07),transparent);animation:shimmer 5s ease infinite}
@keyframes shimmer{0%{left:-100%}100%{left:220%}}
.cred:nth-child(1){animation-delay:.42s}.cred:nth-child(2){animation-delay:.50s}
.cred-inner{padding:22px 20px;display:flex;gap:16px;align-items:flex-start;position:relative;z-index:1}
.cred-seal{width:54px;height:54px;border-radius:14px;flex-shrink:0;background:linear-gradient(145deg,rgba(201,168,76,.18),rgba(201,168,76,.08));border:1px solid var(--border-gold);display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow:0 4px 16px rgba(201,168,76,.12)}
.cred-type{font-size:8px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.7;margin-bottom:5px}
.cred-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:600;color:var(--text);line-height:1.2;margin-bottom:6px}
.cred-issued{font-size:10px;color:var(--muted);margin-bottom:10px}
.cred-desc{font-size:11.5px;color:var(--text3);line-height:1.8}
.cred-desc strong{color:var(--text2);font-weight:600}
.cred-badge{display:inline-block;margin-top:11px;font-size:8.5px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--gold2);background:var(--glow2);border:1px solid var(--border-gold);padding:4px 12px;border-radius:100px}

/* BUILT CARD */
.built-card{width:100%;background:linear-gradient(145deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:18px;overflow:hidden;margin-bottom:12px;box-shadow:0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.03);animation:up .8s .44s ease both}
.built-header{background:linear-gradient(135deg,rgba(201,168,76,.1),rgba(201,168,76,.03));border-bottom:1px solid var(--border);padding:18px 20px;display:flex;align-items:center;gap:13px}
.built-logo{width:46px;height:46px;border-radius:12px;background:linear-gradient(145deg,rgba(201,168,76,.18),rgba(201,168,76,.07));border:1px solid var(--border-gold);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;box-shadow:0 4px 16px rgba(201,168,76,.1)}
.built-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--text)}
.built-sub{font-size:10px;color:var(--muted);margin-top:3px}
.built-badge{margin-left:auto;font-size:8px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;padding:5px 11px;border-radius:100px;color:var(--gold);background:var(--glow);border:1px solid var(--border-gold);flex-shrink:0}
.built-body{padding:20px;display:flex;flex-direction:column;gap:16px}
.built-item{display:flex;gap:14px;align-items:flex-start}
.built-ico{width:36px;height:36px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:15px}
.bi1{background:rgba(29,185,84,.1);border:1px solid rgba(29,185,84,.15)}
.bi2{background:rgba(76,158,255,.1);border:1px solid rgba(76,158,255,.15)}
.bi3{background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.15)}
.bi4{background:rgba(159,111,232,.1);border:1px solid rgba(159,111,232,.15)}
.bt{font-size:12.5px;font-weight:700;color:var(--text);margin-bottom:4px;line-height:1.3}
.bd{font-size:11.5px;color:var(--text3);line-height:1.8}
.bd strong{color:var(--text2);font-weight:600}
.item-div{height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent)}

/* SARA */
.sara{width:100%;border-radius:18px;overflow:hidden;margin-bottom:12px;border:1px solid rgba(76,158,255,.18);background:linear-gradient(145deg,rgba(76,158,255,.05),var(--card));box-shadow:0 8px 40px rgba(0,0,0,.4);animation:up .8s .5s ease both}
.sara-header{padding:18px 20px;border-bottom:1px solid rgba(76,158,255,.1);display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,rgba(76,158,255,.1),rgba(76,158,255,.03))}
.sara-live{width:9px;height:9px;border-radius:50%;background:var(--blue);flex-shrink:0;animation:blink2 2s infinite}
@keyframes blink2{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(76,158,255,.5)}55%{opacity:.6;box-shadow:0 0 0 7px rgba(76,158,255,0)}}
.sara-title{font-family:'Syne',sans-serif;font-size:14.5px;font-weight:700;color:#9BC8FF}
.sara-sub{font-size:9.5px;color:rgba(155,200,255,.4);margin-top:2px}
.sara-body{padding:20px;display:flex;flex-direction:column;gap:14px}
.sara-row{display:flex;gap:10px;align-items:flex-start}
.sara-pill{font-size:8px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;padding:4px 9px;border-radius:100px;flex-shrink:0;margin-top:1px;white-space:nowrap}
.sp-wa{color:#25D366;background:rgba(37,211,102,.09);border:1px solid rgba(37,211,102,.18)}
.sp-tg{color:#229ED9;background:rgba(34,158,217,.09);border:1px solid rgba(34,158,217,.18)}
.sp-ai{color:#9BC8FF;background:rgba(76,158,255,.09);border:1px solid rgba(76,158,255,.18)}
.sp-sh{color:#C4A0FF;background:rgba(159,111,232,.09);border:1px solid rgba(159,111,232,.18)}
.sara-desc{font-size:11.5px;color:var(--text3);line-height:1.8}
.sara-desc strong{color:var(--text2);font-weight:600}

/* FRANCHISE */
.fran{width:100%;background:linear-gradient(145deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:18px;overflow:hidden;margin-bottom:12px;box-shadow:0 8px 40px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.03);animation:up .8s .56s ease both}
.fran-header{padding:18px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px}
.fran-icon{font-size:20px}
.fran-title{font-family:'Syne',sans-serif;font-size:14.5px;font-weight:700;color:var(--text)}
.fran-sub{font-size:10px;color:var(--muted);margin-top:2px}
.fran-body{padding:18px 20px;display:flex;flex-direction:column;gap:8px}
.fran-row{display:flex;align-items:flex-start;gap:12px;padding:12px 14px;border-radius:12px;background:rgba(255,255,255,.018);border:1px solid var(--border);transition:border-color .2s,background .2s}
.fran-row:hover{border-color:var(--border-gold);background:var(--glow)}
.fran-num{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;color:var(--gold);width:26px;flex-shrink:0;text-align:center;margin-top:-1px;opacity:.7}
.fran-text{font-size:11.5px;color:var(--text3);line-height:1.7}
.fran-text strong{color:var(--text2);font-weight:600}

/* CASE STUDY */
.case{width:100%;background:linear-gradient(145deg,rgba(239,68,68,.05),var(--card));border:1px solid rgba(239,68,68,.14);border-radius:18px;overflow:hidden;margin-bottom:12px;box-shadow:0 8px 40px rgba(0,0,0,.4);animation:up .8s .62s ease both}
.case-header{padding:18px 20px;border-bottom:1px solid rgba(239,68,68,.1);display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,rgba(239,68,68,.08),rgba(239,68,68,.02))}
.case-icon{font-size:20px}
.case-title{font-family:'Syne',sans-serif;font-size:14.5px;font-weight:700;color:var(--text)}
.case-sub{font-size:10px;color:var(--muted);margin-top:2px}
.case-tag{margin-left:auto;font-size:8px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:5px 10px;border-radius:100px;flex-shrink:0;color:#FF9999;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2)}
.case-body{padding:20px;display:flex;flex-direction:column;gap:12px}
.case-metric{display:flex;gap:12px;align-items:center;padding:12px 14px;border-radius:12px;background:rgba(255,255,255,.02);border:1px solid var(--border)}
.case-num{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;background:linear-gradient(135deg,var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;white-space:nowrap;flex-shrink:0}
.case-lbl{font-size:11.5px;color:var(--text3);line-height:1.6}
.case-lbl strong{color:var(--text2);font-weight:600}
.case-story{font-size:12px;color:var(--text3);line-height:1.85;padding:16px;border-radius:12px;background:rgba(255,255,255,.015);border:1px solid var(--border)}
.case-story strong{color:var(--text2);font-weight:600}

/* SERVICES */
.svc-wrap{width:100%;display:flex;flex-direction:column;gap:8px}
.svc{background:linear-gradient(145deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:16px;padding:18px 16px;display:flex;gap:13px;align-items:flex-start;transition:border-color .22s,box-shadow .22s;box-shadow:0 4px 20px rgba(0,0,0,.3);animation:up .8s ease both}
.svc:hover{border-color:var(--border-gold);box-shadow:0 4px 30px rgba(201,168,76,.08)}
.svc:nth-child(1){animation-delay:.64s}.svc:nth-child(2){animation-delay:.70s}
.svc:nth-child(3){animation-delay:.76s}.svc:nth-child(4){animation-delay:.82s}
.svc:nth-child(5){animation-delay:.88s}
.sico{width:42px;height:42px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px}
.s1{background:rgba(29,185,84,.09);border:1px solid rgba(29,185,84,.14)}
.s2{background:rgba(159,111,232,.09);border:1px solid rgba(159,111,232,.14)}
.s3{background:rgba(76,158,255,.09);border:1px solid rgba(76,158,255,.14)}
.s4{background:rgba(201,168,76,.09);border:1px solid rgba(201,168,76,.14)}
.s5{background:rgba(239,68,68,.09);border:1px solid rgba(239,68,68,.14)}
.stitle{font-size:13px;font-weight:700;color:var(--text);margin-bottom:5px;line-height:1.3}
.sdesc{font-size:11.5px;color:var(--text3);line-height:1.8}
.sdesc strong{color:var(--text2);font-weight:600}
.stag{display:inline-block;margin-top:8px;font-size:8px;letter-spacing:1.2px;text-transform:uppercase;color:var(--gold);background:var(--glow);border:1px solid var(--border-gold);padding:4px 10px;border-radius:100px;font-weight:700}

/* LINKS */
.links{width:100%;display:flex;flex-direction:column;gap:8px;margin-bottom:4px}
.lcard{background:linear-gradient(145deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:16px;padding:15px 18px;display:flex;align-items:center;gap:13px;text-decoration:none;color:inherit;transition:border-color .22s,box-shadow .22s;box-shadow:0 4px 20px rgba(0,0,0,.3);animation:up .8s ease both;-webkit-tap-highlight-color:transparent}
.lcard:nth-child(1){animation-delay:.7s}.lcard:nth-child(2){animation-delay:.76s}
.lcard:nth-child(3){animation-delay:.82s}.lcard:nth-child(4){animation-delay:.88s}.lcard:nth-child(5){animation-delay:.94s}
.lcard:hover,.lcard:active{border-color:var(--border-gold);box-shadow:0 4px 30px rgba(201,168,76,.08)}
.lico{width:40px;height:40px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px}
.i1{background:rgba(37,211,102,.09);border:1px solid rgba(37,211,102,.14)}
.i2{background:rgba(201,168,76,.09);border:1px solid rgba(201,168,76,.14)}
.i3{background:rgba(76,158,255,.09);border:1px solid rgba(76,158,255,.14)}
.i4{background:rgba(100,100,100,.12);border:1px solid rgba(150,150,150,.18)}
.i5{background:rgba(159,111,232,.09);border:1px solid rgba(159,111,232,.14)}
.ltxt{flex:1;min-width:0}
.lt{font-size:13px;font-weight:700;color:var(--text)}
.ls{font-size:10.5px;color:var(--muted);margin-top:2px}
.larr{color:var(--gold);opacity:.38;font-size:18px;transition:transform .2s,opacity .2s;flex-shrink:0}
.lcard:hover .larr,.lcard:active .larr{transform:translateX(5px);opacity:1}

.foot{margin-top:52px;font-size:9.5px;color:var(--dim);text-align:center;letter-spacing:.5px;animation:up .8s 1.1s ease both;line-height:1.8}
.foot span{color:var(--gold)}

@keyframes up{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:400px){.wrap{padding:44px 14px 68px}.sn{font-size:16px}.cred-title{font-size:16px}.built-body,.sara-body,.fran-body,.case-body{padding:16px 14px}}
</style>
</head>
<body>
<div class="bg"><div class="orb o1"></div><div class="orb o2"></div><div class="orb o3"></div><div class="orb o4"></div></div>
<div class="wrap">

<!-- HERO -->
<div class="av-wrap">
  <div class="av-ring"><div class="av-inner">GG</div></div>
  <div class="live-dot"></div>
</div>
<h1 class="name">Gazul Gafoor</h1>
<p class="serif-title"><em>Operations Manager &amp; F&B Systems Architect</em></p>
<p class="tagline-sub">I build restaurants that run <strong>without chaos</strong> — automated, consistent, and franchise-ready across the GCC.</p>
<div class="role-strip">
  <span class="rtag rg">🍗 Lusso Chicken Ops</span>
  <span class="rtag rb">🤖 AI System Builder</span>
  <span class="rtag rp">📋 Franchise Systems</span>
  <span class="rtag rd">GCC · 5 Countries</span>
</div>
<div class="grule"></div>

<!-- WHO I AM -->
<p class="sec" style="animation:up .8s .3s ease both">Who I Am</p>
